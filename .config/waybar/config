{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 32,
    "modules-left": ["hyprland/window","custom/music"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["custom/cpuinfo","bluetooth", "custom/wifi","pulseaudio", "backlight", "battery", "clock", "custom/lock", "custom/power"],

    "hyprland/workspaces": {
       "on-scroll-up": "hyprctl dispatch workspace -1",
       "on-scroll-down": "hyprctl dispatch workspace +1",
        "sort-by-name": true,
        "format": " {icon} ",
        "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": [],
        },
        "format-icons": {
            "default": "о®ҙ ",
        },
    },
    "custom/music": {
        "format": "пҖҒ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }} - {{ artist }}'",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl -a play-pause",
        "on-click-right": "playerctl next",
        "max-length": 50
    },


    "hyprland/window": {
    "format": "{}",
    "min-length": 5,
    "max-length": 30,


    // === Window Titles ===

    "rewrite": {
        // == Desktop ==
        "": "<span foreground='#89b4fa'>пҚҷ </span> Hyprland",

        // == Terminal ==
        "~": "оҜҠ  Terminal",
        "zsh": "оҜҠ  Terminal",
        "kitty": "оҜҠ  Terminal",
        "sejjy@archlinux:(.*)": "оҜҠ  Terminal",
        "(.*)sejjy@archlinux:~": "оҜҠ  Terminal",

        // == Browser ==
        "(.*)Mozilla Firefox": "<span foreground='#f38ba8'>у°Ҳ№ </span> Firefox",
        "(.*) вҖ” Mozilla Firefox": "<span foreground='#f38ba8'>у°Ҳ№ </span> Firefox",

        "(.*)Zen Browser": "<span foreground='#cdd6f4'>у°Ҳ№ </span> Zen Browser",
        "(.*) вҖ” Zen Browser": "<span foreground='#cdd6f4'>у°Ҳ№ </span> $1",

        // == Development ==
        "(.*) - Visual Studio Code": "<span foreground='#89b4fa'>у°Ёһ </span> $1",
        "(.*)Visual Studio Code": "<span foreground='#89b4fa'>у°Ёһ </span> Visual Studio Code",

        "Godot": "<span foreground='#89b4fa'>оҷҹ </span> Godot Engine",
        "Godot Engine - (.*)": "<span foreground='#89b4fa'>оҷҹ </span> $1",
        "(.*) - Godot Engine": "<span foreground='#89b4fa'>оҷҹ </span> $1",


        // == Media ==
        "(.*)Spotify Free": "<span foreground='#a6e3a1'>пҶј </span> Spotify",
        "(.*)Spotify Premium": "<span foreground='#a6e3a1'>пҶј </span> Spotify Premium",

        "OBS(.*)": "<span foreground='#a6adc8'>у°җҢ </span> OBS Studio",

        "VLC media player": "<span foreground='#fab387'>у°•ј </span> VLC Media Player",
        "(.*) - VLC media player": "<span foreground='#fab387'>у°•ј </span> $1",

        "GNU Image Manipulation Program": "<span foreground='#a6adc8'>пҢё </span> GNU Image Manipulation Program",

        "qView": "пҖҫ  qView",

        "(.*).jpg": "пҖҫ  $1.jpg",
        "(.*).png": "пҖҫ  $1.png",
        "(.*).svg": "пҖҫ  $1.svg",

        // == Social ==
        "vesktop": "<span foreground='#89b4fa'>пҮҝ </span> Discord",
        "(.*)WebCord(.*)": "<span foreground='#89b4fa'>пҮҝ </span> Discord",
        "вҖў Discord(.*)": "Discord$1",
        "(.*)Discord(.*)": "<span foreground='#89b4fa'>пҮҝ </span> $1Discord$2",

        // == Documents ==
        "ONLYOFFICE Desktop Editors": "<span foreground='#f38ba8'>оәЁ </span> OnlyOffice Desktop",

        "(.*).docx": "<span foreground='#89b4fa'>пҮӮ </span> $1.docx",
        "(.*).xlsx": "<span foreground='#a6e3a1'>пҮғ </span> $1.xlsx",
        "(.*).pptx": "<span foreground='#fab387'>пҮ„ </span> $1.pptx",
        "(.*).pdf": "<span foreground='#f38ba8'>пҮҒ </span> $1.pdf",


        // == System ==
        "Timeshift-gtk": "<span foreground='#a6e3a1'>п”җ </span> Timeshift",

        "Authenticate": "п’ң  Authenticate"
        },

        // === Click actions ===
        "on-click": "hyprctl dispatch focus_window",
        "on-middle-click": "hyprctl dispatch kill_window",
        "on-click-right": "hyprctl dispatch move_window",
        "on-scroll-up": "hyprctl dispatch window_up",
        "on-scroll-down": "hyprctl dispatch window_down"
    },

    "clock": {
        "timezone": "Asia/Calcutta",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "пҒі  {:%d/%m/%Y}",
        "format": "пҖ—  {:%H:%M}"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },

    "battery": {
        "states": {
        "full": 100,
        "good": 99,
        "warning": 30,
        "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["у°Ғј", "у°ҒҪ", "у°Ғҫ", "у°Ғҝ", "у°ӮҖ", "у°ӮҒ", "у°ӮӮ"],
        "format-full": "уұғҢ {capacity}%",
        "format-warning": "у°Ғ» {capacity}%",
        "format-critical": "уұғҚ  {capacity}%",
        "format-charging": "уұҳ–  {capacity}%",

        "on-click-right": "kitty --title 'batstat' bash -c batstat",
        "tooltip-format": "Discharging: {time}",
        "tooltip-format-charging": "Charging: {time}",
        "interval": 1,
        "min-length": 6,
        "max-length": 6
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}",
        "format-muted": "п‘Ұ",
        "format-icons": {
            "default": ["пҖҰ", "пҖ§", "пҖЁ "]
        },
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "у°Ӯ°",
        "format-disabled": "у°ӮІ",
        "format-connected": "у°Ӯұ",
        "format-connected-battery": "у°Ӯұ",

        "tooltip-format":
        "{num_connections} connected",
        "tooltip-format-disabled":
        "Bluetooth Disabled",
        "tooltip-format-connected":
        "{num_connections} connected\n{device_enumerate}",
        "tooltip-format-enumerate-connected":
        "{device_alias}",
        "tooltip-format-enumerate-connected-battery":
        "{device_alias}: {device_battery_percentage}%",

        "on-click-right": "kitty --title 'у°ӮҜ  Bluetooth TUI' bash -c bluetui",
        "interval": 1,
        "min-length": 1,
        "max-length": 1
    },

    "custom/wifi": {
        "exec": "~/.config/waybar/scripts/wifi-status.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true,
        "on-click": "~/.config/waybar/scripts/wifi-menu.sh",
        "on-click-right": "kitty nmtui"
    },

    "custom/cpuinfo": {
        "exec": "~/.config/waybar/scripts/cpu-temp.sh",
        "return-type": "json",
        "format": "{}",
        "tooltip": true,
        "interval": 5,
        "min-length": 8,
        "max-length": 8
    },

    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "пҖЈ",
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "wlogout &",
        "format": "вҸ»"
    }
}
