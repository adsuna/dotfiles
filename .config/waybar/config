        "tooltip-format":"SSID:{essid}\nStrength:{signalStrength}\nDownload:{bandwidthDownBits}\nUpload:{bandwidthUpBits}"
    },
    "backlight": {
        "scroll-step": 5,
        "device": "intel_backlight",
        "format": "{icon} {percent}",
        "format-icons": ["Óéć", "ÓŹď", "ÓŹĎ", "ÓŹŹ", "ÓŹé", "ÓŹć", "ÓŹä", "ÓŹą", "Óéõ"],
        "tooltip-format":""
    },

    "battery": {
        "states": {
        "full": 100,
        "good": 99,
        "warning": 30,
        "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā"],
        "format-full": "ůĪÉĆ {capacity}%",
        "format-warning": "ůįĀĽ {capacity}%",
        "format-critical": "ůĪÉć  {capacity}%",
        "format-charging": "ůĪėĖ  {capacity}%",

        "on-click-right": "kitty --class waybar-btop --title 'btop' bash -c btop",
        "tooltip-format": "Discharging: {time}",
        "tooltip-format-charging": "Charging: {time}",
        "interval": 1,
        "min-length": 6,
        "max-length": 6
    },

    "pulseaudio": {
        "scroll-step": 5, // %, can be a float

        "format": "{icon} {volume}",
