    },

    "custom/tempinfo": {
        "exec": "~/.config/waybar/scripts/temps.sh",
        "return-type": "json",
        "format": "{}",
        "tooltip": true,
        "interval": 5,
    },

    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "ÔÄ£",
    },
    "custom/power": {
