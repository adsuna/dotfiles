        "format-icons": {
            "default": ["ÔÄ¶", "ÔÄß", "ÔÄ® "]
        },
        "on-click": "pavucontrol",
        "on-click-right": "amixer set Master toggle"
    },

    "bluetooth": {
        "format": "ůįāį",
        "format-disabled": "ůįā≤",
        "format-connected": "ůįāĪ",
        "format-connected-battery": "ůįāĪ",

        "tooltip-format":
