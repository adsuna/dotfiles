    },
    
    "battery": {
        "states": {
        "full": 100,
        "good": 99,
        "warning": 30,
        "critical": 15
        },    
        "format": "{icon} {capacity}%",
        "format-icons": ["ˇ░ü╝", "ˇ░üŻ", "ˇ░üż", "ˇ░ü┐", "ˇ░éÇ", "ˇ░éü", "ˇ░éé"],
        "format-full": "ˇ▒âî {capacity}%",
        "format-warning": "ˇ░ü╗ {capacity}%",
        "format-critical": "ˇ▒âŹ  {capacity}%",
        "format-charging": "ˇ▒śľ  {capacity}%",
    
        "on-click-right": "kitty --title 'batstat' bash -c batstat",
        "tooltip-format": "Discharging: {time}",
        "tooltip-format-charging": "Charging: {time}",
        "interval": 1,
        "min-length": 6,
