{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 32,
    "modules-left": [],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["custom/music","pulseaudio", "backlight", "battery", "clock", "custom/lock", "custom/power"],
    "hyprland/workspaces": {
         "disable-scroll": true,
         "sort-by-name": true,
         "format": " {icon} ",
         "format-icons": {
             "default": "Όχ┤",
         },
     },
    "custom/music": {
        "format": "ΎΑΒ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 20
    },
    "clock": {
        "timezone": "Asia/Calcutta",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "ΎΒ│  {:%d/%m/%Y}",
        "format": "ΎΑΩ  {:%H:%M}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    
    "battery": {
        "states": {
        "full": 100,
        "good": 99,
        "warning": 30,
        "critical": 15
        },    
        "format": "{icon} {capacity}%",
        "format-icons": ["≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ"],
        "format-full": "≤▒ΔΝ {capacity}%",
        "format-warning": "≤░Β╗ {capacity}%",
        "format-critical": "≤▒ΔΞ  {capacity}%",
        "format-charging": "≤▒αΨ  {capacity}%",
    
        "on-click-right": "kitty --title 'batstat' bash -c batstat",
        "tooltip-format": "Discharging: {time}",
        "tooltip-format-charging": "Charging: {time}",
        "interval": 1,
        "min-length": 6,
        "max-length": 6
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-muted": "ΎΣο",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
        },
        "on-click": "pavucontrol"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "ΎΑμ",
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "wlogout &",
        "format": "έΠ╗"
    }
}
